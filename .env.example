# NovaSaaS Customer Success AI System - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# OpenAI / AI Configuration
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_USER=novasaas
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=novasaas
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://novasaas:your-secure-password-here@postgres:5432/novasaas

# =============================================================================
# Twilio (WhatsApp)
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_URL=https://your-domain.com/webhooks/whatsapp

# =============================================================================
# Gmail / Google Cloud
# =============================================================================
GMAIL_SERVICE_ACCOUNT_FILE=/app/credentials/gmail-service-account.json
GMAIL_DELEGATED_USER=support@yourdomain.com
GCP_PROJECT_ID=your-gcp-project-id
GMAIL_TOPIC_NAME=gmail-notifications

# =============================================================================
# Kafka
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CONSUMER_GROUP=novasaas-consumer

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# Application Settings
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-for-jwt-and-sessions

# =============================================================================
# Frontend
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AGENT_URL=http://localhost:8001
